// ==========================================
// 定数バッファ: C++側から毎フレーム送られてくるパラメータ
// register(b0) = 定数バッファスロット0番に配置
// ==========================================
cbuffer cb0 : register(b0)
{
    float time; // 経過時間（秒）- アニメーション用
    float resX; // 画面幅（ピクセル）- アスペクト比補正用
    float resY; // 画面高さ（ピクセル）- アスペクト比補正用
    float padding; // パディング（HLSLは16バイト境界に合わせる必要がある）
};

// ==========================================
// 入力構造体: 頂点シェーダーから受け取るデータ
// 画面全体を覆う2つの三角形の各頂点情報
// ==========================================
struct PS_INPUT
{
    float4 Position : SV_POSITION; // 画面上の座標（ピクセル座標）
    float4 Diffuse : COLOR0; // 頂点色（今回は使用しない）
    float2 TexCoord : TEXCOORD0; // テクスチャ座標（0.0〜1.0）
};

// ==========================================
// メイン関数: ピクセルシェーダーのエントリーポイント
// 画面の各ピクセルごとに1回ずつ実行される
// 戻り値: SV_TARGET = そのピクセルの最終色
// ==========================================
float4 main(PS_INPUT input) : SV_TARGET
{
    // ==========================================
    // ステップ1: UV座標の正規化とアスペクト比補正
    // ==========================================
    
    // UV座標を 0.0〜1.0 から -1.0〜1.0 の範囲に変換
    // 画面中央が (0, 0) になる
    float2 uv = (input.TexCoord * 2.0) - 1.0;
    
    // X座標をアスペクト比で補正（縦横比を維持）
    // 例: 1920x1080なら uv.x に 1.778（16:9）を掛ける
    // これにより正方形が歪まないようになる
    uv.x *= (resX / resY);

    // ==========================================
    // ステップ2: 擬似3D（パースペクティブ）の計算
    // ==========================================
    
    // Y座標の絶対値を取って、画面を上下対称にする
    // +0.1 は除算エラー防止（yが0になるのを防ぐ）
    float y = abs(uv.y) + 0.1;
    
    // パースペクティブ変換（遠近法）
    // uv.x / y   : X方向は遠くに行くほど縮む
    // 1.0 / y    : Y方向は「奥行き」を表す（小さいほど遠い）
    // この計算で「床が奥に向かって広がる」視覚効果が生まれる
    float2 gridUV = float2(uv.x / y, 1.0 / y);
    
    // 時間経過で奥から手前にスクロール
    // gridUV.y を減らすことで「奥から流れてくる」演出
    // * 2.0 はスクロール速度（大きいほど速い）
    gridUV.y -= time * 2.0;

    // ==========================================
    // ステップ3: グリッド線の描画
    // ==========================================
    
    // グリッドのマス目を計算
    // * 5.0 = グリッドの密度（数値が大きいほど細かいマス目）
    // frac() = 小数部分のみを取り出す（0.0〜1.0の繰り返しパターン）
    // - 0.5 = 中心を0にずらす（-0.5〜0.5の範囲）
    // abs() = 絶対値を取る（0.0〜0.5の範囲になる）
    float2 grid = abs(frac(gridUV * 5.0) - 0.5);
    
    // 線の太さを計算（奥に行くほど細くなる）
    // 0.05 / y : yが大きい（手前）ほど線が太く、小さい（奥）ほど細い
    float lineThickness = 0.05 / y;
    
    // smoothstep(edge0, edge1, x) : edge0〜edge1の範囲で滑らかに補間
    // lineThickness → 0.0 の範囲で1.0→0.0に変化
    // これにより「線の境界がぼやける」効果（アンチエイリアス）
    // X方向とY方向の線を足し合わせる
    float lines = smoothstep(lineThickness, 0.0, grid.x) +
                  smoothstep(lineThickness, 0.0, grid.y);

    // ==========================================
    // ステップ4: フォグ効果（遠方の暗転）
    // ==========================================
    
    // smoothstep(0.0, 1.5, y) : yが0.0〜1.5の範囲で0.0→1.0に変化
    // y が小さい（奥）ほど fog は 0.0 に近く（暗い）
    // y が大きい（手前）ほど fog は 1.0 に近い（明るい）
    // これにより「奥が霞んで見える」演出
    float fog = smoothstep(0.0, 1.5, y);

    // ==========================================
    // ステップ5: 最終色の計算
    // ==========================================
    
    // ベースカラー: シアン（水色）系の発光色
    // R=0.0, G=0.5, B=1.0 = 青みがかった水色
    // lines を掛けることで「線がある部分だけ光る」
    // fog を掛けることで「奥が暗くなる」
    float3 color = float3(0.0, 0.5, 1.0) * lines * fog;

    // 最終出力: RGB + アルファ（不透明）
    // float4(color, 1.0) = (R, G, B, A)
    // A=1.0 = 完全不透明
    return float4(color, 1.0);
}